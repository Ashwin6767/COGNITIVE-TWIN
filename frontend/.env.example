# Cognitive Twin — Frontend Environment Variables
# Copy this to .env.local for local development

# Backend API URL (full URL to the API, including /api prefix)
# For local dev:
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# For production (set in Vercel dashboard):
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com/api

# WebSocket URL (for real-time notifications)
# For local dev:
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/ws/stream

# For production:
# NEXT_PUBLIC_WS_URL=wss://your-backend.onrender.com/api/ws/stream
